# Copy to .env and fill in your RDS + API Gateway values for production EC2 deploy
DATABASE_URL=postgresql://shopadmin:YOUR_PASSWORD@your-rds-endpoint.region.rds.amazonaws.com:5432/shopdb
PORT=4000
NODE_ENV=production
DB_SSL=true
CORS_ORIGIN=http://YOUR_EC2_PUBLIC_IP

# Frontend build arg (rebuild web image after changing)
VITE_API_URL=https://YOUR_API_ID.execute-api.YOUR_REGION.amazonaws.com/prod
